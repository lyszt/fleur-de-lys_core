PKG_NAME="binutils"
PKG_VER="2.44"
do_configure() {
    sed '6009s/$add_dir//' -i ltmain.sh
    mkdir -v build && cd build
    ../configure --prefix=/tools \
        --build=$(../config.guess) \
        --host=$LFS_TGT \
        --disable-nls \
        --enable-shared \
        --enable-gprofng=no \
        --disable-werror \
        --enable-64-bit-bfd \
        --enable-new-dtags \
        --enable-default-hash-style=gnu
}
do_compile() { cd build && make $MAKEFLAGS; }
do_install() { cd build && make install; }
