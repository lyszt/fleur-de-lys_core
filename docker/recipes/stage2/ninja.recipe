PKG_NAME="ninja"
PKG_VER="1.12.1"
SRC_URI="https://github.com/ninja-build/ninja/archive/refs/tags/v${PKG_VER}.tar.gz"
SRC_URI_MIRRORS="https://codeload.github.com/ninja-build/ninja/tar.gz/refs/tags/v${PKG_VER}"
do_configure() { /usr/bin/python3 configure.py --bootstrap; }
do_compile() { true; }
do_install() { install -vm755 ninja /tools/bin/; }
