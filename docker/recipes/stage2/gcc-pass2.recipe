PKG_NAME="gcc"
PKG_VER="15.1.0"
do_configure() {
    tar -xf /sources/gmp-6.3.0.tar.xz && mv gmp-6.3.0 gmp
    tar -xf /sources/mpfr-4.2.2.tar.xz && mv mpfr-4.2.2 mpfr
    tar -xf /sources/mpc-1.3.1.tar.gz && mv mpc-1.3.1 mpc
    sed -e '/m64=/s/lib64/lib/' -i gcc/config/i386/t-linux64
    sed '/thread_header =/s/@.*@/gthr-posix.h/' -i libgcc/Makefile.in libstdc++-v3/include/Makefile.in
    mkdir -v build && cd build
    ../configure --build=$(../config.guess) \
        --host=$LFS_TGT \
        --target=$LFS_TGT \
        LDFLAGS_FOR_TARGET="-L$PWD/$LFS_TGT/libgcc" \
        --prefix=/tools \
        --with-build-sysroot=/tools \
        --enable-default-pie \
        --enable-default-ssp \
        --enable-lto \
        --disable-nls \
        --disable-multilib \
        --disable-libatomic \
        --disable-libgomp \
        --disable-libquadmath \
        --disable-libsanitizer \
        --disable-libssp \
        --disable-libvtv \
        --enable-languages=c,c++
}
do_compile() { cd build && make $MAKEFLAGS profiledbootstrap; }
do_install() { cd build && make install && ln -sv gcc /tools/bin/cc; }
