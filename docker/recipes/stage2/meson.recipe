PKG_NAME="meson"
PKG_VER="1.7.0"
SRC_URI="https://github.com/mesonbuild/meson/releases/download/${PKG_VER}/meson-${PKG_VER}.tar.gz"
SRC_URI_MIRRORS="https://codeload.github.com/mesonbuild/meson/tar.gz/refs/tags/${PKG_VER}"
do_configure() { true; }
do_compile() { true; }
do_install() {
    mkdir -p /tools/lib/python3.13/site-packages/
    cp -rv mesonbuild /tools/lib/python3.13/site-packages/
    install -vm755 meson.py /tools/bin/meson
    sed -i '1s|^#.*|#!/usr/bin/python3|' /tools/bin/meson
    PYTHONPATH="/tools/lib/python3.13/site-packages" /usr/bin/python3 -c "import mesonbuild"
}
