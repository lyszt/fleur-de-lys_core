PKG_NAME="llvm-bootstrap"
PKG_VER="19-host"

do_configure() { :; }
do_compile() { :; }
do_install() {
    mkdir -pv /tools/bin

    cat > /tools/bin/$LFS_TGT-gcc << EOF
#!/bin/sh
    exec /usr/bin/clang --target=$LFS_TGT --sysroot=/tools "\$@"
EOF

    cat > /tools/bin/$LFS_TGT-g++ << EOF
#!/bin/sh
    exec /usr/bin/clang++ --target=$LFS_TGT --sysroot=/tools "\$@"
EOF

    cat > /tools/bin/$LFS_TGT-cpp << EOF
#!/bin/sh
    exec /usr/bin/clang -E --target=$LFS_TGT --sysroot=/tools "\$@"
EOF

    chmod +x /tools/bin/$LFS_TGT-gcc /tools/bin/$LFS_TGT-g++ /tools/bin/$LFS_TGT-cpp
}
